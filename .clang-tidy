---
# Conservative clang-tidy configuration — warning-only, no WarningsAsErrors.
# Enabled check families:
#   bugprone-*              — common bug patterns
#   performance-*           — performance anti-patterns
#   clang-analyzer-*        — static analysis (Clang SA)
#   modernize-use-nullptr   — NULL → nullptr
#   modernize-use-override  — missing override/final
#   modernize-use-emplace   — push_back({...}) → emplace_back(...)
#   modernize-use-default-member-init — in-class member initializers
#   cppcoreguidelines-pro-type-member-init — uninitialized members
#
# Intentionally excluded for now:
#   readability-*           — style/naming, too noisy for initial rollout
#   modernize-* (bulk)      — only specific modernize checks enabled above
#   cppcoreguidelines-* (bulk) — only member-init enabled above

Checks: >
  bugprone-*,
  performance-*,
  clang-analyzer-*,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-emplace,
  modernize-use-default-member-init,
  cppcoreguidelines-pro-type-member-init,
  -bugprone-easily-swappable-parameters,
  -bugprone-exception-escape

# No warnings-as-errors — this is a warning-only rollout.
WarningsAsErrors: ""

# Use the compile_commands.json generated by CMake.
# clang-tidy picks it up automatically when run from the build directory
# or when passed via -p <build-dir>.

HeaderFilterRegex: "^.*cpp/src/.*\\.h$"

CheckOptions:
  - key: modernize-use-default-member-init.UseAssignment
    value: "true"
