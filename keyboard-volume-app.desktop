#!/usr/bin/env xdg-open
[Desktop Entry]
Type=Application
Name=Keyboard Volume App
Comment=Per-app volume control via keyboard with OSD
Exec=/home/adiker/Dokumenty/keyboard-volume-app/cpp/build/keyboard-volume-app
Path=/home/adiker/Dokumenty/keyboard-volume-app
Icon=/home/adiker/Dokumenty/keyboard-volume-app/resources/icon.png
Terminal=false
StartupNotify=false
Categories=Utility;Audio;
X-KDE-autostart-condition=kded5|Module|kded_autostart|true
